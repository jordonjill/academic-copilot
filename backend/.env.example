# =========================
# Auth
# =========================
ACCESS_KEY="CHANGE_ME_ACCESS_KEY"
ADMIN_ACCESS_KEY="CHANGE_ME_ADMIN_ACCESS_KEY"

# =========================
# Model Providers
# =========================
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_COMPAT_USER_AGENT="AcademicCopilot/1.0"

# Unified OpenAI-compatible model keys
DEEPSEEK_API_KEY=""
QWEN_API_KEY=""
OLLAMA_API_KEY="ollama"

# =========================
# Search / External APIs
# =========================
TAVILY_API_KEY="YOUR_TAVILY_API_KEY"
JINA_API_KEY="YOUR_JINA_API_KEY"      # optional, Jina limited mode if empty
ZOTERO_API_KEY="YOUR_ZOTERO_API_KEY"  # optional, only if zotero MCP server enabled

# =========================
# Supervisor Runtime
# =========================
SUPERVISOR_AGENT_ID="supervisor"
SUPERVISOR_MAX_STEPS=8
SUPERVISOR_MAX_SUBAGENT_CALLS_PER_AGENT=2
SUPERVISOR_MAX_WALL_TIME_SECONDS=900
WORKFLOW_MAX_WALL_TIME_SECONDS=900
CHAT_TURN_TIMEOUT_SECONDS=600
LLM_REQUEST_TIMEOUT_SECONDS=180
CHAT_MAX_WORKERS=4
LLM_CACHE_MAX_SIZE=128
CONTEXT_MESSAGES_WINDOW_DEFAULT=12
CONTEXT_MESSAGES_WINDOW_SUPERVISOR=20
CONTEXT_TRACE_WINDOW=8
CONTEXT_TRACE_MAX_ITEMS=64
LTM_MAX_WORKERS=2

# Recommendation:
# LLM_REQUEST_TIMEOUT_SECONDS < CHAT_TURN_TIMEOUT_SECONDS <
# min(SUPERVISOR_MAX_WALL_TIME_SECONDS, WORKFLOW_MAX_WALL_TIME_SECONDS).
# Note:
# CHAT_TURN_TIMEOUT_SECONDS (asyncio wait_for) does not forcibly stop a running
# executor thread immediately. Keep CHAT_MAX_WORKERS conservative for stability.

# =========================
# Memory Pipeline
# =========================
MEMORY_PIPELINE_ENABLED=true
STM_TOKEN_THRESHOLD=6000
STM_KEEP_RECENT=6
LTM_DRAIN_TIMEOUT_SECONDS=5

# =========================
# Persistence
# =========================
DATA_DIR="data"
USERS_DIR="data/users"
CONVERSATION_DB="data/conversations.db"

# =========================
# Tools / Exports
# =========================
JINA_TIMEOUT_SECONDS=120
WEB_CRAWL_MAX_WORKERS=5
EXPORT_BASE_DIR="data/exports"
TOOL_CATALOG_PATH=""  # optional override, default is backend/config/tools.yaml
LOCAL_DOC_ROOT="."
TOOLS_STRICT_STARTUP=true

# =========================
# API Rate Limiting
# =========================
CHAT_RATE_LIMIT_ENABLED=true
CHAT_RATE_LIMIT_REQUESTS=60
CHAT_RATE_LIMIT_WINDOW_SECONDS=60

# NOTE:
# LOCAL_DOC_ROOT is used by the unified internal `filesystem` tool.
# It defaults to backend working directory when empty.
